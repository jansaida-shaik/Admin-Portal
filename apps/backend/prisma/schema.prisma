generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        BigInt   @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  role      Role     @default(STAFF)
  
  // Extensible user profiles
  phone     String?  // Contact Line
  department String? @default("GENERAL")
  locationId BigInt?
  location   Location? @relation("UserLocation", fields: [locationId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions           Transaction[] @relation("UserTransactions")
  sentTransactions       Transaction[] @relation("SentTransactions")
  receivedTransactions   Transaction[] @relation("ReceivedTransactions")
  assignments       Assignment[]
  mobileNumbers     MobileNumber[]
  mobileAssignments MobileAssignment[]
  serviceRequests   ServiceRequest[]
  salaries          Salary[]
  attendances       Attendance[]
  leaves            Leave[]
  leaveQuota        LeaveQuota?
  dailyChecklists   DailyChecklist[]
  weeklyChecklists  WeeklyChecklist[]
  monthlyChecklists MonthlyChecklist[]
  payrolls          Payroll[]
  dutyAllocations   DutyAllocation[]
  lostDamagedDevices LostDamagedDevice[]
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

model Category {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     Item[]
}

model Vendor {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     Item[]
}

model Location {
  id        BigInt   @id @default(autoincrement())
  name      String
  city      String?
  isMaster  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]   @relation("UserLocation")

  stocks           Stock[]
  transactionsFrom Transaction[] @relation("FromLocation")
  transactionsTo   Transaction[] @relation("ToLocation")
  assignments      Assignment[]
  internetBills    InternetBill[]
  lostDamagedDevices LostDamagedDevice[]
  dutyAllocations  DutyAllocation[]
  cleaningStocks   CleaningStock[]
  subscriptions    Subscription[]
}

model Item {
  id          BigInt   @id @default(autoincrement())
  name        String
  description String?
  categoryId  BigInt
  vendorId    BigInt?
  attachments String?  // Store JSON array of uploaded file URLs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category     Category        @relation(fields: [categoryId], references: [id])
  vendor       Vendor?         @relation(fields: [vendorId], references: [id])
  stocks       Stock[]
  transactions Transaction[]
  assignments  Assignment[]
  repairs      RepairHistory[]
  serviceRequests ServiceRequest[]
  lostDamagedDevices LostDamagedDevice[]
}

model Stock {
  id         BigInt   @id @default(autoincrement())
  itemId     BigInt
  locationId BigInt
  quantity   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  item       Item     @relation(fields: [itemId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])

  @@unique([itemId, locationId])
}

model Transaction {
  id             BigInt          @id @default(autoincrement())
  itemId         BigInt
  quantity       Int
  type           TransactionType
  fromLocationId BigInt?
  toLocationId   BigInt?
  userId         BigInt
  sentById       BigInt?
  receivedById   BigInt?
  transactionDate DateTime?       @default(now())
  vendor         String?
  attachments    String?         // Store JSON array of uploaded invoice files
  createdAt      DateTime        @default(now())

  item         Item      @relation(fields: [itemId], references: [id])
  fromLocation Location? @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("ToLocation", fields: [toLocationId], references: [id])
  user         User      @relation("UserTransactions", fields: [userId], references: [id])
  sentBy       User?     @relation("SentTransactions", fields: [sentById], references: [id])
  receivedBy   User?     @relation("ReceivedTransactions", fields: [receivedById], references: [id])
}

enum TransactionType {
  IN
  OUT
  TRANSFER
}

model Assignment {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt
  itemId     BigInt
  locationId BigInt
  quantity   Int       @default(1)
  status     String    @default("ACTIVE")
  assignedAt DateTime  @default(now())
  returnedAt DateTime?

  user       User      @relation(fields: [userId], references: [id])
  item       Item      @relation(fields: [itemId], references: [id])
  location   Location  @relation(fields: [locationId], references: [id])
}

model MobileNumber {
  id          BigInt    @id @default(autoincrement())
  number      String    @unique
  provider    String?
  planDetails String?
  status      String    @default("AVAILABLE")
  assignedTo  String?   
  isDummy     Boolean   @default(false) // True for dummy test cards
  userId           BigInt?
  assignedAt       DateTime?
  nextRechargeDate DateTime?

  user        User?     @relation(fields: [userId], references: [id])
  assignments MobileAssignment[]
  recharges   MobileRecharge[]
}

model InternetBill {
  id          BigInt    @id @default(autoincrement())
  provider    String
  planDetails  String?
  speed        Int?
  monthlyCost  Float?
  dueDate      DateTime?
  billingCycle String?   @default("MONTHLY")
  status       String    @default("ACTIVE")
  locationId   BigInt?
  attachments  String?   // Store JSON array of payment receipt uploads
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  location    Location? @relation(fields: [locationId], references: [id])
}

model InternetExpense {
  id          BigInt   @id @default(autoincrement())
  date        DateTime
  payee       String
  type        String
  reference   String?
  debit       Float?
  credit      Float?
  amount      Float
  balanceType String
  createdAt   DateTime @default(now())
}

model RepairHistory {
  id           BigInt   @id @default(autoincrement())
  itemId       BigInt
  repairDate   DateTime @default(now())
  cost         Float    @default(0)
  description  String
  vendorName   String?
  status       String   @default("COMPLETED")
  createdAt    DateTime @default(now())

  item         Item     @relation(fields: [itemId], references: [id])
}

model MobileAssignment {
  id          BigInt    @id @default(autoincrement())
  mobileId    BigInt
  userId      BigInt?
  assignedTo  String?
  assignedAt  DateTime  @default(now())
  returnedAt  DateTime?
  status      String    @default("ACTIVE")

  mobile      MobileNumber @relation(fields: [mobileId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
}

model MobileRecharge {
  id           BigInt   @id @default(autoincrement())
  mobileId     BigInt
  rechargeDate DateTime @default(now())
  amount       Float
  planDetails  String?
  createdAt    DateTime @default(now())

  mobile       MobileNumber @relation(fields: [mobileId], references: [id])
}

// ─── NEW ENTERPRISE MODULES ──────────────────────────────────────────────

model ServiceRequest {
  id          BigInt   @id @default(autoincrement())
  title       String
  description String
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status      String   @default("PENDING") // PENDING, APPROVED, IN_PROGRESS, RESOLVED, REJECTED
  slaDueDate  DateTime?
  userId      BigInt
  itemId      BigInt?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  item        Item?    @relation(fields: [itemId], references: [id])
}

model OnboardingChecklist {
  id            BigInt   @id @default(autoincrement())
  employeeName  String
  role          String
  status        String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  
  // Discrete item boolean trackers
  laptop        Boolean  @default(false)
  mouse         Boolean  @default(false)
  keyboard      Boolean  @default(false)
  headset       Boolean  @default(false)
  simCard       Boolean  @default(false)
  
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PlacementOrder {
  id          BigInt   @id @default(autoincrement())
  title       String
  branchName  String
  quantity    Int      @default(1)
  status      String   @default("PENDING") // PENDING, FULFILLED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Salary {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  amount      Float
  effectiveDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model Attendance {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  date        DateTime @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      String   @default("PRESENT") // PRESENT, ABSENT, HALF_DAY
  
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Leave {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  reason      String
  leaveType   String   @default("CASUAL") // SICK, CASUAL, EARNED
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  user        User     @relation(fields: [userId], references: [id])
}

model LeaveQuota {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @unique
  sickLeave   Int      @default(12)
  casualLeave Int      @default(12)
  earnedLeave Int      @default(0)
  
  user        User     @relation(fields: [userId], references: [id])
}

model DailyChecklist {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  date        DateTime @db.Date
  task        String
  isCompleted Boolean  @default(false)
  photoUrl    String?  // Mandatory photo for proof
  
  user        User     @relation(fields: [userId], references: [id])
}

model WeeklyChecklist {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  weekStart   DateTime @db.Date
  task        String
  isCompleted Boolean  @default(false)
  photoUrl    String?
  
  user        User     @relation(fields: [userId], references: [id])
}

model MonthlyChecklist {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  month       String   // e.g., '2026-06'
  task        String
  isCompleted Boolean  @default(false)
  photoUrl    String?
  
  user        User     @relation(fields: [userId], references: [id])
}

model Payroll {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt
  month         String   // e.g. '2026-06'
  basicSalary   Float
  allowances    Float    @default(0)
  deductions    Float    @default(0)
  netPay        Float
  status        String   @default("PENDING") // PENDING, PAID
  paymentDate   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

model DutyAllocation {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  locationId  BigInt
  shiftTime   String   // e.g., '09:00 AM - 06:00 PM'
  assignedDate DateTime @db.Date
  
  user        User     @relation(fields: [userId], references: [id])
  location    Location @relation(fields: [locationId], references: [id])
}

model Subscription {
  id              BigInt   @id @default(autoincrement())
  name            String
  vendor          String
  plan            String?
  category        String?
  licenseCount    Int?
  cost            Float
  billingFrequency String  // MONTHLY, QUARTERLY, HALF_YEARLY, YEARLY
  purchaseDate    DateTime? @db.Date
  renewalDate     DateTime @db.Date
  autoRenew       Boolean  @default(false)
  paymentMethod   String?
  owner           String?
  notes           String?
  attachments     String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  locationId      BigInt?
  location        Location? @relation(fields: [locationId], references: [id])
}

model LostDamagedDevice {
  id              BigInt   @id @default(autoincrement())
  itemId          BigInt
  userId          BigInt?
  locationId      BigInt?
  status          String   // LOST, DAMAGED, STOLEN, UNDER_REPAIR, RECOVERED
  incidentDate    DateTime @db.Date
  description     String
  attachments     String?
  insuranceDetails String?
  recoveryStatus  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  item            Item     @relation(fields: [itemId], references: [id])
  user            User?    @relation(fields: [userId], references: [id])
  location        Location? @relation(fields: [locationId], references: [id])
}

model EmailTemplate {
  id              BigInt   @id @default(autoincrement())
  name            String   @unique
  subject         String
  body            String
  category        String?
  variables       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reminders       ReminderSchedule[]
}

model Webhook {
  id              BigInt   @id @default(autoincrement())
  name            String
  url             String
  method          String   @default("POST")
  headers         String?
  events          String?  // JSON array of events
  payloadTemplate String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ReminderSchedule {
  id              BigInt   @id @default(autoincrement())
  name            String
  module          String   // SUBSCRIPTIONS, ASSETS, etc.
  referenceId     BigInt?  // ID of the record
  reminderDate    DateTime @db.Date
  recipients      String   // JSON array of emails
  templateId      BigInt?
  status          String   @default("PENDING") // PENDING, SENT, FAILED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  template        EmailTemplate? @relation(fields: [templateId], references: [id])
}

// ─── HOUSEKEEPING INVENTORY ──────────────────────────────────────────────

model CleaningItem {
  id          BigInt   @id @default(autoincrement())
  name        String
  description String?
  unit        String   @default("pcs")
  createdAt   DateTime @default(now())
  
  stocks      CleaningStock[]
}

model CleaningStock {
  id          BigInt   @id @default(autoincrement())
  itemId      BigInt
  locationId  BigInt
  quantity    Int      @default(0)
  minStock    Int      @default(10)
  lastRestock DateTime @default(now())

  item        CleaningItem @relation(fields: [itemId], references: [id])
  location    Location     @relation(fields: [locationId], references: [id])

  @@unique([itemId, locationId])
}

// ─── AUDIT LOGS ──────────────────────────────────────────────

model VendorMergeLog {
  id              BigInt   @id @default(autoincrement())
  primaryVendorId BigInt
  mergedVendorId  BigInt
  mergedVendorName String
  mergedByUserId  BigInt
  mergedAt        DateTime @default(now())
  details         String?
}
